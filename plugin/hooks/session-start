#!/usr/bin/env bash
# SessionStart hook for wikiforge plugin
# Detects .wiki-compiler.yml (preferred) or legacy .wiki-compiler.json and
# injects wiki context based on mode.

set -euo pipefail

# Walk up from $PWD to find .wiki-compiler.yml (preferred) or .json (legacy)
config_file=""
config_ext=""
dir="$PWD"
while [ "$dir" != "/" ]; do
  if [ -f "$dir/.wiki-compiler.yml" ]; then
    config_file="$dir/.wiki-compiler.yml"
    config_ext="yml"
    break
  fi
  if [ -f "$dir/.wiki-compiler.json" ]; then
    config_file="$dir/.wiki-compiler.json"
    config_ext="json"
    break
  fi
  dir="$(dirname "$dir")"
done

# No config found — exit silently (plugin installed but project has no wiki)
if [ -z "$config_file" ]; then
  exit 0
fi

project_root="$(dirname "$config_file")"

# Read a top-level scalar field from the config, handling both JSON and
# YAML without requiring js-yaml. For YAML we only support top-level
# scalars — the session-start hook doesn't need nested fields.
get_config_field() {
  local field=$1
  local default=$2
  if [ "$config_ext" = "json" ]; then
    node -e "const c=require('$config_file'); console.log(c.$field || '$default')" 2>/dev/null || echo "$default"
  else
    # YAML scalar parsing is delegated to a helper script. Handles
    # double-quoted, single-quoted, and unquoted values; strips inline
    # comments ONLY on unquoted values so `name: "Project #42"` is
    # preserved. Inline heredoc-in-$() breaks bash parsing when the
    # node script contains single quotes (regex), so this is external.
    local helper="$(dirname "${BASH_SOURCE[0]}")/_read-yaml-field.js"
    local val
    val=$(node "$helper" "$config_file" "$field" 2>/dev/null)
    if [ -z "$val" ]; then
      echo "$default"
    else
      echo "$val"
    fi
  fi
}

output_path=$(get_config_field output "")
mode=$(get_config_field mode staging)
name=$(get_config_field name Project)
if [ "$mode" = "codebase" ]; then
  wiki_mode=codebase
else
  wiki_mode=knowledge
fi

if [ -z "$output_path" ]; then
  exit 0
fi

index_file="$project_root/$output_path/index.md"
state_file="$project_root/$output_path/.compile-state.json"

# Escape string for JSON embedding
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

if [ ! -f "$index_file" ]; then
  context="[Wikiforge] Wiki configured for \"$name\" but not yet compiled. Run /wiki-compile to build your knowledge base."
else
  # `topics` is an object map (new schema) — count keys. Object.keys() also
  # works on legacy array shape (returns numeric index keys), so this line
  # is compatible with both.
  topic_count=$(node -e "const s=require('$state_file'); console.log(Object.keys(s.topics||{}).length)" 2>/dev/null || echo "?")
  last_compiled=$(node -e "const s=require('$state_file'); console.log(s.last_compiled || 'unknown')" 2>/dev/null || echo "unknown")
  auto_update=$(get_config_field auto_update off)

  # Stale detection: count source files changed since last compile
  stale_warning=""
  if [ "$auto_update" = "prompt" ] && [ "$last_compiled" != "unknown" ]; then
    # Read source paths from .compile-state.json (written by the compiler)
    # rather than parsing the config. State is always JSON, so this works
    # regardless of whether the config is YAML or legacy JSON. It also
    # correctly reflects what was actually compiled last time, which is
    # what stale-detection should compare against.
    sources_json=$(node -e "const s=require('$state_file'); (s.source_locations||[]).forEach(p => console.log(p))" 2>/dev/null)
    changed_count=0
    while IFS= read -r src_path; do
      if [ -n "$src_path" ] && [ -d "$project_root/$src_path" ]; then
        # Create a reference file with the last_compiled date
        ref_file=$(mktemp)
        touch -t "$(echo "$last_compiled" | sed 's/-//g')0000" "$ref_file" 2>/dev/null
        if [ "$wiki_mode" = "codebase" ]; then
          # Codebase mode: watch knowledge files + key source files, not just .md
          count=$(find "$project_root/$src_path" \
            \( -name "README.md" -o -name "CLAUDE.md" -o -name "AGENTS.md" -o -name "ARCHITECTURE.md" \
               -o -name "CONTRIBUTING.md" -o -name "CHANGELOG.md" \
               -o -name "*.proto" -o -name "*.graphql" \
               -o -name "openapi.yaml" -o -name "openapi.json" \
               -o -name "ADR-*.md" \
               -o -name "docker-compose.yml" -o -name "Dockerfile" \
               -o -name ".env.example" \
               -o -name "package.json" -o -name "go.mod" -o -name "Cargo.toml" -o -name "pyproject.toml" \) \
            -not -path "*/node_modules/*" -not -path "*/.git/*" -not -path "*/dist/*" \
            -not -path "*/vendor/*" -not -path "*/__pycache__/*" -not -path "*/.build/*" \
            -newer "$ref_file" 2>/dev/null | wc -l | tr -d ' ')
        else
          # Knowledge mode: watch .md files
          count=$(find "$project_root/$src_path" -name "*.md" -newer "$ref_file" 2>/dev/null | wc -l | tr -d ' ')
        fi
        changed_count=$((changed_count + count))
        rm -f "$ref_file"
      fi
    done <<< "$sources_json"

    if [ "$changed_count" -gt 0 ]; then
      stale_warning="\n\n⚠️ Wiki may be stale — $changed_count files changed since last compile ($last_compiled). Run /wiki-compile to update."
    fi
  fi

  case "$mode" in
    staging)
      context="[Wikiforge] A compiled knowledge wiki is available for \"$name\".\nLocation: $output_path\nTopics: $topic_count | Last compiled: $last_compiled\nMode: staging (supplements existing context)\n\nWhen you need deep context on a topic, read ${output_path}index.md to see available topics, then read specific topic articles. This wiki synthesizes source files into topic-based briefings — reading one topic article replaces reading 10-20 raw files.\n\nWiki articles are read-only synthesis. Never modify wiki/ files directly — they are regenerated by /wiki-compile.${stale_warning}"
      ;;
    recommended)
      context="[Wikiforge] \"$name\" knowledge wiki active.\nLocation: $output_path\nTopics: $topic_count | Last compiled: $last_compiled\nMode: recommended\n\nFor project context, start with ${output_path}index.md. Read topic articles before reading raw source files. Fall back to raw sources only when the wiki article is insufficient or you need granular detail.\n\nWiki articles are read-only synthesis — regenerated by /wiki-compile.${stale_warning}"
      ;;
    primary)
      context="[Wikiforge] \"$name\" wiki is the primary knowledge source.\nLocation: $output_path\nTopics: $topic_count | Last compiled: $last_compiled\n\nRead ${output_path}index.md at session start. Only read raw source files when a wiki article's Sources section points you there for detail.\n\nWiki articles are read-only synthesis — regenerated by /wiki-compile.${stale_warning}"
      ;;
    *)
      context="[Wikiforge] Wiki available for \"$name\" at $output_path ($topic_count topics, last compiled: $last_compiled). Run /wiki-compile to update.${stale_warning}"
      ;;
  esac
fi

escaped_context=$(escape_for_json "$context")

# Output in correct format per platform
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$escaped_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$escaped_context"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$escaped_context"
fi

exit 0
